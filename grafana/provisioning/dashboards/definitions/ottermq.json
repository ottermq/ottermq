{
  "dashboard": {
    "title": "OtterMQ Metrics",
    "tags": ["ottermq", "messaging"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Message Rates",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "ottermq_messages_publish_rate",
            "legendFormat": "Publish Rate",
            "refId": "A"
          },
          {
            "expr": "ottermq_messages_deliver_rate",
            "legendFormat": "Delivery Rate",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "messages/sec",
            "show": true
          },
          {
            "show": true
          }
        ],
        "xaxis": {
          "show": true,
          "mode": "time"
        },
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "pointradius": 5,
        "legend": {
          "show": true,
          "alignAsTable": true,
          "avg": true,
          "current": true,
          "max": true,
          "min": true
        }
      },
      {
        "id": 2,
        "title": "Message Counts",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "ottermq_messages_published_total",
            "legendFormat": "Published",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "orientation": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {
              "mode": "thresholds"
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Delivered Messages",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "ottermq_messages_delivered_total",
            "legendFormat": "Delivered",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {
              "mode": "thresholds"
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Connections",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 4,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "ottermq_connection_count",
            "legendFormat": "Active",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {
              "mode": "palette-classic"
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Queues",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 4,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "ottermq_queue_count",
            "legendFormat": "Total",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {
              "mode": "palette-classic"
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Queue Depths",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "ottermq_queue_message_depth",
            "legendFormat": "{{queue}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {
            "label": "messages",
            "show": true
          },
          {
            "show": true
          }
        ],
        "xaxis": {
          "show": true,
          "mode": "time"
        },
        "lines": true,
        "fill": 0,
        "linewidth": 2,
        "legend": {
          "show": true,
          "alignAsTable": true,
          "current": true
        }
      },
      {
        "id": 7,
        "title": "Message Count",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 8,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "ottermq_message_count",
            "legendFormat": "Total Messages",
            "refId": "A"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "green"
                },
                {
                  "value": 1000,
                  "color": "yellow"
                },
                {
                  "value": 10000,
                  "color": "red"
                }
              ]
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Acknowledgments",
        "type": "graph",
        "gridPos": {
          "x": 0,
          "y": 16,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(ottermq_messages_acked_total[1m])",
            "legendFormat": "ACK Rate",
            "refId": "A"
          },
          {
            "expr": "rate(ottermq_messages_nacked_total[1m])",
            "legendFormat": "NACK Rate",
            "refId": "B"
          }
        ],
        "yaxes": [
          {
            "label": "messages/sec",
            "show": true
          },
          {
            "show": true
          }
        ],
        "xaxis": {
          "show": true,
          "mode": "time"
        },
        "lines": true,
        "fill": 1,
        "linewidth": 2,
        "legend": {
          "show": true,
          "alignAsTable": true,
          "avg": true,
          "current": true
        }
      }
    ]
  }
}